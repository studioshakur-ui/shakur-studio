# --- Frontend (Vite) — safe to expose in the browser ---
# Supabase project URL, e.g. https://xxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase publishable (anon) key — meant for browser use
VITE_SUPABASE_ANON_KEY=

# Optional: contact channels rendered in the CTA section
VITE_CONTACT_EMAIL=contact@shakurstudio.com
# Full WhatsApp URL with a real number, e.g. https://wa.me/41700000000
VITE_WHATSAPP_URL=

# Public URL of the ShakurOS API. No secret or provider key here.
VITE_SHAKUROS_API_URL=https://shakuros-api-production.up.railway.app

# --- Edge functions (server side, set via `supabase secrets set ...`) ---
# Provider keys stay server-side only.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# Optional model default kept for legacy OpenAI edge functions.
# OPENAI_MODEL=gpt-4o-mini
# Comma-separated origin allowlist for CORS (defaults to localhost dev).
# CNCS_ALLOWED_ORIGINS=https://shakurstudio.com,https://www.shakurstudio.com
